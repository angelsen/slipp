---
# Generated by ansictl launch
# Deploy {{ project_name }} to {{ target_host }}
#
# Usage: ansible-playbook deploy.yml
#
# Requirements:
#   - ansible-galaxy collection install containers.podman

- name: Deploy {{ project_name }}
  hosts: all
  become: true
  vars:
    ansible_host: {{ target_host }}
    ansible_user: {{ ssh_user }}
    ansible_port: {{ ssh_port }}
    ansible_python_interpreter: {{ ansible_python_interpreter }}
    project_root: {{ project_root }}

  tasks:
    - name: Install Podman
      ansible.builtin.package:
        name: podman
        state: present

    {% for service in services %}
    - name: Create build directory for {{ service.name }}
      ansible.builtin.file:
        path: "/tmp/{{ project_name }}-{{ service.name }}"
        state: directory
        mode: '0755'

    - name: Copy {{ service.name }} Dockerfile
      ansible.builtin.copy:
        src: "{{ service.path }}/Dockerfile"
        dest: "/tmp/{{ project_name }}-{{ service.name }}/Dockerfile"
        mode: '0644'

    - name: Copy {{ service.name }} source
      ansible.posix.synchronize:
        src: "{{ service.path }}/"
        dest: "/tmp/{{ project_name }}-{{ service.name }}/"
        delete: yes
        rsync_opts:
          - "--exclude=node_modules"
          - "--exclude=.venv"
          - "--exclude=__pycache__"
          - "--exclude=.git"
          - "--exclude=dist"
          - "--exclude=build"

    - name: Build {{ service.name }} image
      containers.podman.podman_image:
        name: "{{ project_name }}-{{ service.name }}"
        path: "/tmp/{{ project_name }}-{{ service.name }}"
        force: yes
        state: build

    - name: Run {{ service.name }} container with systemd
      containers.podman.podman_container:
        name: "{{ project_name }}-{{ service.name }}"
        image: "{{ project_name }}-{{ service.name }}"
        state: started
        ports:
          - "{{ service.port }}:{{ service.port }}"
        recreate: yes
        generate_systemd:
          path: /etc/systemd/system
          restart_policy: always
          names: true
          new: true

    - name: Enable {{ service.name }} systemd service
      ansible.builtin.systemd:
        name: "container-{{ project_name }}-{{ service.name }}.service"
        enabled: yes
        daemon_reload: yes
    {% endfor %}

    - name: Display deployed services
      ansible.builtin.debug:
        msg: "{{ project_name }} deployed successfully! Services: {% for service in services %}{{ service.name }}{% if not loop.last %}, {% endif %}{% endfor %}"
