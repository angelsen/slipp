# Generated by slipp launch
# Ansible inventory configuration
all:
  hosts:
{% for name, host in inventory.hosts.items() %}
    {{ name }}:
      ansible_host: {{ host.ansible_host | tojson }}
      ansible_user: {{ host.ansible_user | tojson }}
      ansible_port: {{ host.ansible_port }}
      app_domain: {{ host.app_domain | tojson }}
      admin_email: {{ host.admin_email | tojson }}
      container_runtime: {{ host.container_runtime | tojson }}
{% endfor %}
