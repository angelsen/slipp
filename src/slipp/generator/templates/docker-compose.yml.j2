# Generated by slipp launch
# For local development with Docker Desktop only
# Production uses Podman systemd (see deploy.yml)

services:
{% for service in services %}
  {{ service.name }}:
    build:
      context: {{ service.build_context }}
      dockerfile: Dockerfile
    ports:
      # Loopback-only -- local dev already reaches this via localhost,
      # and this keeps it off the LAN/any other interface for free (see
      # PortResolutionStage's docstring for why 0.0.0.0 is never safe by
      # default on a container-published port).
      - "127.0.0.1:{{ service.host_port }}:{{ service.port }}"
    environment:
      PORT: "{{ service.host_port }}"
{% endfor %}
