# Generated by slipp launch
# For local development with Docker Desktop only
# Production uses Podman systemd (see deploy.yml)

services:
{% for service in services %}
  {{ service.name }}:
    build:
      context: ./{{ service.path.replace(project_root + '/', '') if service.path.startswith(project_root) else service.path }}
      dockerfile: Dockerfile
    ports:
      - "{{ service.port }}:{{ service.port }}"
    environment:
      PORT: "{{ service.port }}"
{% endfor %}
