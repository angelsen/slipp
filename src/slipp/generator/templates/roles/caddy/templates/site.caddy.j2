# Generated by slipp launch ({{ project_name }})
{%- set sites_by_domain = {} %}
{%- for site in caddy_sites %}
	{%- if site.domain not in sites_by_domain %}
		{%- set _ = sites_by_domain.update({site.domain: []}) %}
	{%- endif %}
	{%- set _ = sites_by_domain[site.domain].append(site) %}
{%- endfor %}

{% for domain, sites in sites_by_domain.items() -%}
{{ domain }} {
{%- if sites|length == 1 %}
	{%- set site = sites[0] %}

	reverse_proxy {{ site.upstream_host }}:{{ site.upstream_port }} {
		health_uri /health
		health_interval 30s
		health_timeout 5s
		fail_duration 30s
	}
{%- else %}
	{# Multiple services on same domain - use handle blocks with path routing #}
	{%- for site in sites|sort(attribute='path_prefix', reverse=true) %}

	handle {{ site.path_prefix }}* {
		reverse_proxy {{ site.upstream_host }}:{{ site.upstream_port }} {
			health_uri /health
			health_interval 30s
			health_timeout 5s
			fail_duration 30s
		}
	}
	{%- endfor %}
{%- endif %}

}

{% endfor -%}
