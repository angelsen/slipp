---
# Generated by slipp launch
# Caddy installation and configuration

- name: Install apt-transport-https
  ansible.builtin.apt:
    name: apt-transport-https
    state: present
    update_cache: true

- name: Add Caddy apt repository
  ansible.builtin.deb822_repository:
    name: caddy-stable
    types: [deb, deb-src]
    uris: https://dl.cloudsmith.io/public/caddy/stable/deb/debian
    suites: any-version
    components: main
    signed_by: https://dl.cloudsmith.io/public/caddy/stable/gpg.key
    install_python_debian: true

- name: Install Caddy
  ansible.builtin.apt:
    name: caddy
    state: present
    update_cache: true

- name: Ensure sites directory exists
  ansible.builtin.file:
    path: {{ caddy_sites_dir | tojson }}
    state: directory
    mode: '0755'

- name: Deploy main Caddyfile
  ansible.builtin.template:
    src: Caddyfile.j2
    dest: /etc/caddy/Caddyfile
    mode: '0644'

- name: Deploy site configuration
  ansible.builtin.template:
    src: site.caddy.j2
    dest: {{ (caddy_sites_dir ~ "/" ~ project_name ~ ".caddy") | tojson }}
    mode: '0644'

- name: Validate complete Caddy configuration
  ansible.builtin.command:
    cmd: caddy validate --adapter caddyfile --config /etc/caddy/Caddyfile
  changed_when: false

# Reloaded unconditionally (not notify-triggered) so a config write that
# lands on disk during a play that later fails elsewhere still takes
# effect -- notify handlers only flush at the end of a successful play,
# and a subsequent retry with no further diff would never re-notify,
# silently leaving the running Caddy process out of sync with disk.
- name: Enable and reload Caddy
  ansible.builtin.systemd:
    name: caddy
    enabled: true
    state: reloaded
