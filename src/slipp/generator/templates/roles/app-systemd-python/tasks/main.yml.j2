---
# Generated by slipp launch
# Deploy {{ service.name }} service as a native systemd process (no container)
#
# Runs as the SSH-connecting user (ansible_user), not root - the app has no
# need for a privileged port, so root would only be unnecessary blast
# radius. become: true stays on the play (playbook.yml) for tasks that
# genuinely need it (/etc/systemd/system, systemctl); everything else here
# opts back out with become: false. This also sidesteps a real Ansible
# limitation: ansible.posix.synchronize's rsync shells out its own
# "sudo -u root rsync" over a raw ssh call that never sees
# ansible_become_pass, so it can only work at all without become.
#
# Python itself is uv-managed (uv python install), not an OS package - a
# self-contained interpreter uv fetches directly, so it needs no
# python3-venv package and isn't at the mercy of whatever Python version
# the target distro happens to have packaged.
{% if health_check %}
#
# Restart is wrapped in a block/rescue: the service must report active and
# its health endpoint must return 200, or the previous deployment (code +
# systemd unit, snapshot below includes .venv so rollback needs no
# dependency reinstall) is restored and the play fails.
{% else %}
#
# Restart is wrapped in a block/rescue: if the service doesn't report
# active afterward, recent logs are surfaced and the play fails.
{% endif %}

- name: Install uv
  become: false
  ansible.builtin.shell: curl -LsSf https://astral.sh/uv/install.sh | sh
  args:
    creates: "/home/{{ '{{ ansible_user }}' }}/.local/bin/uv"

- name: Install Python {{ pythonVersion }} (uv-managed)
  become: false
  ansible.builtin.command: "/home/{{ '{{ ansible_user }}' }}/.local/bin/uv python install {{ pythonVersion }}"

{% include "roles/_shared/health_check_snapshot.yml.j2" %}
- name: Create app directory
  ansible.builtin.file:
    path: "/opt/{{ project_name }}-{{ service.name }}"
    state: directory
    mode: '0755'
    owner: "{{ '{{ ansible_user }}' }}"
    group: "{{ '{{ ansible_user }}' }}"

- name: Sync source code
  become: false
  ansible.posix.synchronize:
    src: "{{ service.path }}/"
    dest: "/opt/{{ project_name }}-{{ service.name }}/"
    delete: true
    rsync_opts:
      - "--exclude=.venv"
      - "--exclude=__pycache__"
      - "--exclude=.git"
      - "--exclude=.env.production"
{% for exclude in sync_excludes %}
      - "--exclude={{ exclude }}"
{% endfor %}

- name: Sync dependencies (uv)
  become: false
  ansible.builtin.command: "/home/{{ '{{ ansible_user }}' }}/.local/bin/uv sync --managed-python{% if hasUvLock %} --frozen{% endif %} --no-dev{% if uv_extra %} --extra {{ uv_extra }}{% endif %}"
  args:
    chdir: "/opt/{{ project_name }}-{{ service.name }}"

- name: Ensure environment file exists
  become: false
  ansible.builtin.copy:
    content: ""
    dest: "/opt/{{ project_name }}-{{ service.name }}/.env.production"
    mode: '0600'
    force: false

{% include "roles/_shared/deploy_verify.yml.j2" %}
