---
# Deploy {{ service.name }} service as a native systemd process (no container)
#
# Runs as the SSH-connecting user (ansible_user), not root - the app has no
# need for a privileged port, so root would only be unnecessary blast
# radius. become: true stays on the play (playbook.yml) for tasks that
# genuinely need it (package install, /etc/systemd/system, systemctl);
# everything else here opts back out with become: false.
{% if health_check %}
#
# Restart is wrapped in a block/rescue: the service must report active and
# its health endpoint must return 200, or the previous deployment (code +
# systemd unit, snapshot below includes node_modules so rollback needs no
# dependency reinstall) is restored and the play fails.
{% else %}
#
# Restart is wrapped in a block/rescue: if the service doesn't report
# active afterward, recent logs are surfaced and the play fails.
{% endif %}

- name: Install Node.js
  ansible.builtin.package:
    name:
      - nodejs
      - npm
    state: present

{% include "roles/_shared/health_check_snapshot.yml.j2" %}
- name: Create app directory
  ansible.builtin.file:
    path: "/opt/{{ project_name }}-{{ service.name }}"
    state: directory
    mode: '0755'
    owner: "{{ '{{ ansible_user }}' }}"
    group: "{{ '{{ ansible_user }}' }}"

- name: Sync source code
  become: false
  ansible.posix.synchronize:
    src: "{{ service.path }}/"
    dest: "/opt/{{ project_name }}-{{ service.name }}/"
    delete: true
    rsync_opts:
      - "--exclude=node_modules"
      - "--exclude=.venv"
      - "--exclude=__pycache__"
      - "--exclude=.git"
      - "--exclude=.env.production"
{% for exclude in sync_excludes %}
      - "--exclude={{ exclude }}"
{% endfor %}

- name: Install dependencies
  become: false
  ansible.builtin.command: npm ci
  args:
    chdir: "/opt/{{ project_name }}-{{ service.name }}"

- name: Build application
  become: false
  ansible.builtin.command: npm run build
  args:
    chdir: "/opt/{{ project_name }}-{{ service.name }}"

- name: Ensure environment file exists
  become: false
  ansible.builtin.copy:
    content: ""
    dest: "/opt/{{ project_name }}-{{ service.name }}/.env.production"
    mode: '0600'
    force: false

{% include "roles/_shared/deploy_verify.yml.j2" %}
