---
# Generated by slipp launch
# Deploy {{ project_name }}
#
# Usage: ansible-playbook playbook.yml -i inventory.yml
#
# Requirements installed automatically by `slipp deploy` from requirements.yml
{% for host in hosts_with_services %}

- name: Provision and deploy {{ project_name }}{{ '' if hosts_with_services|length == 1 else ' (' ~ host.host_name ~ ')' }}
  hosts: {{ host.host_name }}
  become: true
{% if host.runtime == 'docker' %}

  pre_tasks:
    - name: Install Docker
      ansible.builtin.package:
        name:
          - docker.io
          - python3-requests
        state: present
{% elif host.runtime == 'podman' %}

  pre_tasks:
    - name: Install Podman
      ansible.builtin.package:
        name: podman
        state: present
{% endif %}
{% if host.infra_roles or host.app_roles %}

  roles:
{% if host.infra_roles %}
    # Infrastructure
{% for role in host.infra_roles %}
    - role: {{ role.name }}
      tags: {{ role.tags | tojson }}
{% endfor %}
{% endif %}
{% if host.app_roles %}

    # Application services
{% for role in host.app_roles %}
    - role: {{ role.name }}
      tags: {{ role.tags | tojson }}
{% endfor %}
{% endif %}
{% else %}

  roles: []
{% endif %}
{% endfor %}
