---
# Generated by slipp launch
# Deploy {{ project_name }}
#
# Usage: ansible-playbook playbook.yml -i inventory.yml
#
# Requirements installed automatically by `slipp deploy` from requirements.yml

- name: Provision and deploy {{ project_name }}
  hosts: all
  become: true
{% if runtime == 'docker' %}

  pre_tasks:
    - name: Install Docker
      ansible.builtin.package:
        name:
          - docker.io
          - python3-requests
        state: present
{% elif runtime == 'podman' %}

  pre_tasks:
    - name: Install Podman
      ansible.builtin.package:
        name: podman
        state: present
{% endif %}

  roles:
    # Infrastructure
{% if not skip_caddy %}
    - role: caddy
      tags: [provision, caddy]
{% elif proxy == 'wg-manage' %}
    - role: wg-manage-exposure
      tags: [provision, wg-manage]
{% endif %}

    # Application services
{% for service in services %}
    - role: app-{{ service.name }}
      tags: [deploy, {{ service.name }}]
{% endfor %}
