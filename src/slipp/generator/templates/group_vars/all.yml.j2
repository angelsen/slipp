---
# Generated by ansictl launch
# Variables for {{ project_name }}

# Project metadata
project_name: {{ project_name }}
project_root: {{ project_root }}
app_domain: {{ app_domain }}

# Service configuration
services:
{% for service in services %}
  - name: {{ service.name }}
    framework: {{ service.framework }}
    port: {{ service.port }}
    image: "{{ project_name }}-{{ service.name }}"
    container_name: "{{ project_name }}-{{ service.name }}"
{% endfor %}

# Caddy configuration
caddy_auto_https: {{ caddy_auto_https }}
caddy_sites_dir: {{ caddy_sites_dir }}
caddy_staging: {{ caddy_staging }}
{% if caddy_email %}
caddy_email: {{ caddy_email }}
{% endif %}
