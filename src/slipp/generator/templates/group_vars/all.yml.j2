---
# Generated by slipp launch
# Variables for {{ project_name }}

# Project metadata
project_name: {{ project_name | tojson }}
project_root: {{ project_root | tojson }}
app_domain: {{ app_domain | tojson }}

# Service configuration
services:
{% for service in services %}
  - name: {{ service.name | tojson }}
    framework: {{ service.framework | tojson }}
    port: {{ service.port }}
{% if runtime != 'systemd' %}
    image: {{ (project_name ~ "-" ~ service.name) | tojson }}
    container_name: {{ (project_name ~ "-" ~ service.name) | tojson }}
{% endif %}
{% endfor %}

# Caddy configuration
caddy_auto_https: {{ caddy_auto_https | tojson }}
caddy_sites_dir: {{ caddy_sites_dir | tojson }}
caddy_staging: {{ caddy_staging | tojson }}
