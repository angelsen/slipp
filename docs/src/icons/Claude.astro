---
/**
 * Claude icon from @lobehub/icons-static-svg
 * Wrapper component for consistent API with other icons
 */
interface Props {
  size?: string | number;
  class?: string;
}

const { size = "1em", class: className } = Astro.props;
const svg = await import("@lobehub/icons-static-svg/icons/claude.svg?raw");
---

<span
  class:list={["icon", className]}
  style={`--icon-size: ${typeof size === "number" ? `${size}px` : size}`}
  set:html={svg.default}
/>

<style>
  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--icon-size);
    height: var(--icon-size);
  }

  .icon :global(svg) {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }
</style>
